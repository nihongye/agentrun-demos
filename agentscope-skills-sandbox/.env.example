# === 模型配置（二选一） ===

# Provider: openai（默认）或 dashscope
MODEL_PROVIDER=openai

# --- OpenAI 兼容接口（MODEL_PROVIDER=openai 时使用）---
OPENAI_API_KEY=sk-your-api-key
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL_NAME=qwen-plus

# --- DashScope 原生 SDK（MODEL_PROVIDER=dashscope 时使用）---
# DASHSCOPE_API_KEY=sk-your-api-key
# DASHSCOPE_API_BASE=
# DASHSCOPE_MODEL_NAME=qwen-plus

# === 沙箱配置 ===
SANDBOX_MANAGER_URL=http://sandbox-manager.example.com
# SANDBOX_MANAGER_TOKEN=your-token
ALL_IN_ONE_SANDBOX_NAME=all-in-one

# === 服务地址 ===
HOST=0.0.0.0
PORT=8080

# === Agent 行为 ===
MAX_ITERS=20
PARALLEL_TOOL_CALLS=false
MODEL_STREAM=true

# === 文件下载 ===
# DOWNLOAD_SECRET=your-secret-key

# === 日志 ===
LOG_LEVEL=INFO
