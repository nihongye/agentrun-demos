FROM node:22-slim

WORKDIR /app

# Copy pre-built dist and node_modules
COPY node_modules/ ./node_modules/
COPY dist/ ./dist/
# Plugin must go into dist/extensions/ where OpenClaw discovers bundled plugins
COPY extensions/agentscope-sandbox/ ./dist/extensions/agentscope-sandbox/
COPY openclaw.mjs ./openclaw.mjs
COPY docs/ ./docs/

# Build-time patch: make all mega chunks share a single SANDBOX_BACKEND_FACTORIES Map
# via globalThis[Symbol.for(...)]. Same fix as E2B integration.
COPY patch-sandbox-map.mjs ./patch-sandbox-map.mjs
RUN node patch-sandbox-map.mjs /app/dist && rm patch-sandbox-map.mjs

# AgentScope exec helper script
COPY agentscope-exec.mjs ./agentscope-exec.mjs

# Config template + entrypoint
COPY openclaw-config-template.agentscope.json ./openclaw-config-template.json
COPY entrypoint.agentscope.sh ./entrypoint.sh
RUN chmod +x /app/entrypoint.sh

EXPOSE 18789

CMD ["/app/entrypoint.sh"]
