{
  "models": {
    "providers": {
      "__LLM_PROVIDER__": {
        "baseUrl": "__LLM_BASE_URL__",
        "apiKey": "__LLM_API_KEY__",
        "api": "openai-completions",
        "models": [
          {
            "id": "__LLM_MODEL_ID__",
            "name": "__LLM_MODEL_NAME__"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "__LLM_PROVIDER__/__LLM_MODEL_ID__"
      },
      "sandbox": {
        "mode": "all",
        "backend": "e2b",
        "workspaceAccess": "rw"
      }
    }
  },
  "plugins": {
    "entries": {
      "e2b-sandbox": {
        "enabled": true,
        "config": {
          "apiUrl": "__E2B_API_URL__",
          "sandboxUrl": "__E2B_SANDBOX_URL__",
          "apiKey": "__E2B_API_KEY__",
          "template": "__E2B_TEMPLATE__",
          "workdir": "/home/user"
        }
      },
      "agentscope-sandbox": {
        "enabled": false,
        "config": {
          "managerUrl": "",
          "managerToken": "",
          "sandboxType": "",
          "workdir": "/workspace"
        }
      }
    }
  },
  "gateway": {
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "token": "__GATEWAY_TOKEN__"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        },
        "responses": {
          "enabled": true
        }
      }
    }
  }
}
