FROM node:22-slim

WORKDIR /app

# Copy pre-built dist and node_modules
# NOTE: Do NOT prune --prod — OpenClaw dist references devDependencies at runtime (LESSONS #28)
COPY node_modules/ ./node_modules/
COPY dist/ ./dist/
COPY extensions/e2b-sandbox/ ./extensions/e2b-sandbox/
COPY openclaw.mjs ./openclaw.mjs
COPY docs/ ./docs/

# Build-time patch: make all mega chunks share a single SANDBOX_BACKEND_FACTORIES Map
# via globalThis[Symbol.for(...)]. Fixes E2B LESSONS #37 (esbuild code splitting).
COPY patch-sandbox-map.mjs ./patch-sandbox-map.mjs
RUN node patch-sandbox-map.mjs /app/dist && rm patch-sandbox-map.mjs

# E2B exec helper script — spawned by OpenClaw exec runtime to run commands in sandbox
COPY e2b-exec.mjs ./e2b-exec.mjs

# Config template + entrypoint — generates openclaw.json from environment variables at startup
COPY openclaw-config-template.json ./openclaw-config-template.json
COPY entrypoint.sh ./entrypoint.sh
RUN chmod +x /app/entrypoint.sh

EXPOSE 18789

CMD ["/app/entrypoint.sh"]
