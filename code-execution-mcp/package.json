{
  "name": "code-execution-mcp",
  "version": "1.0.0",
  "description": "MCP server for multi-language code execution (Python, JavaScript, TypeScript, Java, Shell) over streamable HTTP",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "tsx": "^4.19.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  }
}
